{
  "expo": {
    "name": "إلكترونيات النعمان",
    "slug": "al-nouman-electronics",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nouman-electronics",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000B26"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nouman.electronics"
    },
    "android": {
      "package": "com.nouman.electronics",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000B26"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "8bf35811-3364-4375-a1d8-12a6ef021c85"
      }
    }
  }
}
